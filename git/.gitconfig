[include]
	path = ~/.gitconfig.local

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true # use n and N to move between diff section
	features = catppuccin-mocha

[delta "catppuccin-mocha"]
	blame-palette = "#1e1e2e #181825 #313244 #45475a #585b70"
	commit-decoration-style = "box ul"
	dark = true
	file-decoration-style = "#cdd6f4"
	file-style = "#cdd6f4"
	hunk-header-decoration-style = "box ul"
	hunk-header-file-style = "bold"
	hunk-header-line-number-style = "bold #a6adc8"
	hunk-header-style = "file line-number syntax"
	line-numbers = true
	line-numbers-left-style = "#6c7086"
	line-numbers-minus-style = "bold #f38ba8"
	line-numbers-plus-style = "bold #a6e3a1"
	line-numbers-right-style = "#6c7086"
	line-numbers-zero-style = "#6c7086"
	minus-emph-style = "bold syntax #53354a"
	minus-style = "syntax #2d1b2e"
	plus-emph-style = "bold syntax #2b4a3f"
	plus-style = "syntax #1c3a2d"
	map-styles = \
		bold purple => syntax "#553b6e", \
		bold blue => syntax "#2a3f6f", \
		bold cyan => syntax "#1e4d58", \
		bold yellow => syntax "#4d4020"
	syntax-theme = "Catppuccin Mocha"
	zero-style = "syntax"

[color]
	ui = auto

[diff]
	algorithm = histogram
	colorMoved = plain
	renames = true
	mnemonicPrefix = true

[branch]
	sort = -committerdate

[column]
	ui = auto

[tag]
	sort = version:refname

[alias]
	st = status
	ci = commit
	# Legacy — kept for muscle memory. Prefer `sw` for branch switching.
	co = checkout
	# Modern, unambiguous replacements for `git checkout`
	sw = switch
	res = restore
	# Current branch only
	lg = log --graph --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ar)%Creset'
	# All branches + remotes — useful when rebasing or checking divergence
	lga = log --graph --all --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ar)%Creset'
	po = !git push origin $(git branch --show-current)
	# --force-with-lease: refuse if remote has unknown commits
	# --force-if-includes: also verify fetched remote commits are in local history
	yolo = !git push --force-with-lease --force-if-includes origin $(git branch --show-current)
	# --sort flag removed: redundant with branch.sort = -committerdate in config
	br = branch --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
	pr = !gh pr create --fill
	# Undo last commit, keep all changes staged — nothing is lost
	undo = reset --soft HEAD~1
	# Create a fixup commit for a given SHA — pairs with rebase.autoSquash = true
	# Usage: git fixup <sha>
	fixup = !git commit --fixup
	# List local branches whose remote tracking branch is gone (merged/deleted PRs)
	# Pipe to `git branch -d $(git gone)` to bulk-delete them
	gone = !git fetch -p && git branch -vv | grep ': gone]' | awk '{print $1}'

[pull]
	ff = only

[push]
	default = simple
	autoSetupRemote = true
	followTags = true

[fetch]
	fsckObjects = true
	prune = true
	pruneTags = true

[receive]
	# Completes the fsck triangle: transfer (all ops) + fetch (incoming) + receive (push target).
	# Relevant when pushing to a local bare repo or self-hosted remote (Gitea, etc.).
	# GitHub enforces its own fsck server-side, but this is correct defense-in-depth.
	fsckObjects = true

[merge]
	tool = vimdiff
	# Show common ancestor in conflict markers (requires Git ≥ 2.35)
	# <<<<<<< HEAD / ||||||| base / ======= / >>>>>>> branch
	# The base section shows what the code looked like before both sides diverged,
	# making it possible to reason about intent rather than just picking a side.
	conflictstyle = zdiff3

[commit]
	verbose = true

[help]
	autocorrect = prompt

[rebase]
	# Auto-apply fixup!/squash! commits during rebase — pairs with Lazygit's
	# "create fixup commit" (ctrl-f). No more manual reordering in the todo list.
	autoSquash = true
	# Stash dirty worktree before rebase, restore after. Eliminates the
	# "cannot rebase: you have unstaged changes" interruption.
	autostash = true
	# When rebasing a branch, also update any branches stacked on top of it.
	# Essential for stacked PRs — prevents downstream branches from breaking.
	# Requires Git ≥ 2.38.
	updateRefs = true

[rerere]
	# Remember how merge conflicts were resolved and replay the resolution
	# automatically if the same conflict appears again (e.g. on repeated rebases).
	enabled = true
	# Stage rerere-resolved files automatically — no manual `git add` needed
	# before `git rebase --continue`.
	autoupdate = true

[transfer]
	fsckObjects = true

[init]
	defaultBranch = main
; [gpg]
; 	format = ssh
; [commit]
; 	gpgsign = true
